<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="310dp"
    android:layout_height="500dp"
    android:background="@drawable/border_window"
    android:orientation="vertical">

    <TextView
        android:id="@+id/joystick_map_tips"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:text="@string/joystick_map_tips"/>

    <SearchView
        android:id="@+id/joystick_map_searchView"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="44dp"
        android:layout_marginTop="44dp"
        android:iconifiedByDefault="true"
        app:showAsAction="collapseActionView|ifRoom"
        android:queryHint="@string/app_search_tips" />

    <ImageButton
        android:id="@+id/map_close"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:src="@drawable/ic_close"
        android:tint="@color/textSecondary"
        android:theme="@style/RippleWhite" />

    <FrameLayout
        android:layout_marginTop="88dp"
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <com.baidu.mapapi.map.MapView
            android:id="@+id/map_joystick"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
        </com.baidu.mapapi.map.MapView>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_round_button"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_position"
            android:tint="@color/colorAccent" />

        <ImageButton
            android:id="@+id/btnGo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="90dp"
            android:background="@drawable/bg_round_button"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_position"
            app:tint="@color/cartoonGreen"
            android:elevation="4dp" />

        <LinearLayout
            android:id="@+id/route_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_route_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:elevation="3dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/route_add"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/joystick_route_add"
                android:src="@drawable/ic_route_add"
                android:tint="@color/colorAccent" />

            <TextView
                android:id="@+id/route_count"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0 个点"
                android:textColor="@color/textPrimary"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/route_play"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/joystick_route_play"
                android:src="@drawable/ic_play"
                android:tint="@color/colorAccent" />

            <ImageButton
                android:id="@+id/route_clear"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/joystick_route_clear"
                android:src="@drawable/ic_route_clear"
                android:tint="@color/textSecondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/map_search_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_dropdown"
            android:elevation="4dp"
            android:visibility="gone">

            <ListView
                android:id="@+id/map_search_list_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:divider="@color/divider"
                android:dividerHeight="0.5dp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
